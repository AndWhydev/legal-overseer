{
  "name": "legal-overseer",
  "version": "0.1.0",
  "private": true,
  "description": "AI legal operations system for Australian law firms — on-prem agentic platform with mandatory human review",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "dashboard": "tsx scripts/dashboard.ts",
    "overseer:tick": "tsx scripts/overseer-tick.ts",
    "overseer:start": "tsx scripts/overseer-start.ts",
    "inbox:monitor": "tsx scripts/inbox-monitor.ts",
    "licence:generate": "tsx scripts/generate-licence.ts",
    "update": "bash scripts/update.sh",
    "update:check": "tsx -e \"import('./src/updater/index.js').then(async m => { const s = await m.runUpdateCheck(); console.log(JSON.stringify(s, null, 2)); })\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.150",
    "@anthropic-ai/sdk": "^0.98.0",
    "better-sqlite3": "^12.10.0",
    "debug": "^4.4.3",
    "file-type": "^22.0.1",
    "imapflow": "^1.2.10",
    "mailparser": "^3.9.8",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.11",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.13",
    "opossum": "^9.0.0",
    "rate-limiter-flexible": "^11.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
