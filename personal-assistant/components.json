{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "radix-nova",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "src/app/globals.css",
    "baseColor": "neutral",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "tabler",
  "rtl": false,
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "menuColor": "default",
  "menuAccent": "subtle",
  "registries": {
    "@ai-elements": "https://ai-sdk.dev/elements/api/registry/{name}.json",
    "@shadcnhooks": "https://shadcn-hooks.com/r/{name}.json",
    "@prompt-kit": "https://www.prompt-kit.com/c/{name}.json",
    "@assistant-ui": "https://r.assistant-ui.com/{name}.json",
    "@tool-ui": "https://www.tool-ui.com/r/{name}.json",
    "@kibo-ui": "https://www.kibo-ui.com/r/{name}.json",
    "@animate-ui": "https://animate-ui.com/r/{name}.json",
    "@plate": "https://platejs.org/r/{name}.json",
    "@gaia": "https://ui.heygaia.io/r/{name}.json",
    "@elevenlabs-ui": "https://ui.elevenlabs.io/r/{name}.json",
    "@inferencesh": "https://ui.inference.sh/r/{name}.json",
    "@magicui": "https://magicui.design/r/{name}.json",
    "@motion-primitives": "https://motion-primitives.com/r/{name}.json",
    "@blocks-so": "https://blocks.so/r/{name}.json",
    "@nteract": "https://nteract-elements.vercel.app/r/{name}.json"
  }
}
