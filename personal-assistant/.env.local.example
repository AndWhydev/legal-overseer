NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Integrations portal — credential encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
CREDENTIALS_KEY=your-256-bit-base64-key

# Email delivery (or connect via Settings → Integrations portal)
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=invoices@yourdomain.com

# OAuth apps (for integrations portal)
NEXT_PUBLIC_APP_URL=https://app.bitbit.chat
ASANA_CLIENT_ID=your-asana-client-id
ASANA_CLIENT_SECRET=your-asana-client-secret
CALENDLY_CLIENT_ID=your-calendly-client-id
CALENDLY_CLIENT_SECRET=your-calendly-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
