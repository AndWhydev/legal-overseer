# ─────────────────────────────────────────────────────────────────────
# BitBit Overseer — environment variables
# Copy to .env and fill in. The defaults below are for local dev.
# ─────────────────────────────────────────────────────────────────────

# Operator notifications (email)
# Destination for overseer escalations, system alerts, briefings, approvals.
ADMIN_EMAIL=you@example.com

# SMTP transport. Use any provider (Postmark, SendGrid, Resend, Mailgun,
# a self-hosted relay, or a Gmail App Password).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=postmaster@example.com
SMTP_PASS=replace-with-real-password

# Optional. Defaults: SMTP_FROM=SMTP_USER, SMTP_SECURE auto-detected
# (true only when SMTP_PORT=465). Override SMTP_SECURE=true to force TLS.
# SMTP_FROM="BitBit Overseer <bot@example.com>"
# SMTP_SECURE=true

# Optional. Included as a link in escalation emails so the operator can
# jump straight to the dashboard project view. No default.
# DASHBOARD_URL=http://127.0.0.1:3000

# ─────────────────────────────────────────────────────────────────────
# Anthropic
# ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────
# Path to the SQLite database. Defaults to ./data/bitbit.db in dev,
# /data/bitbit.db in production.
# DATABASE_PATH=./data/bitbit.db

# ─────────────────────────────────────────────────────────────────────
# Task processor
# ─────────────────────────────────────────────────────────────────────
ENABLE_TASK_PROCESSOR=false
TASK_POLL_INTERVAL=5000

# ─────────────────────────────────────────────────────────────────────
# Overseer + dashboard
# ─────────────────────────────────────────────────────────────────────
# Overseer tick interval (ms). 10 minutes is the default.
OVERSEER_INTERVAL_MS=600000
# Dashboard port (bound to 127.0.0.1 only).
DASHBOARD_PORT=3000

# ─────────────────────────────────────────────────────────────────────
# Briefings
# ─────────────────────────────────────────────────────────────────────
BRIEFING_ENABLED=false
BRIEFING_CRON=0 8 * * *

# ─────────────────────────────────────────────────────────────────────
# R&D Scout (CheekyGlo skill — optional)
# ─────────────────────────────────────────────────────────────────────
ENABLE_RD_SCOUT=false

# ─────────────────────────────────────────────────────────────────────
# SEO Backlinks skill (optional)
# Off-site SEO: discovers platforms, generates articles, submits or
# queues them, and writes a weekly report. Cron defaults: campaign
# pass Sun 20:00 UTC, report Sun 21:00 UTC.
# ─────────────────────────────────────────────────────────────────────
# ENABLE_SEO_BACKLINKS=false
# SEO_BACKLINKS_CRON=0 20 * * 0
# SEO_BACKLINKS_REPORT_CRON=0 21 * * 0
# DEVTO_API_KEY=
# HASHNODE_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# Inbox Monitor — five dedicated IMAP inboxes, each routes to a
# different downstream pipeline. Set ENABLE_INBOX_MONITOR=true and
# fill in *only* the slots you actually use; unconfigured slots are
# skipped silently.
#
# IMAP/SMTP host + port are auto-detected for Gmail, Office 365,
# iCloud, Fastmail, Yahoo, Zoho. For any other provider, set the
# *_IMAP_HOST and *_SMTP_HOST env vars explicitly.
# ─────────────────────────────────────────────────────────────────────
ENABLE_INBOX_MONITOR=false
# Override the 2-minute default. Min ~30s recommended for IMAP politeness.
# INBOX_POLL_INTERVAL_MS=120000
# Where downloaded attachments land. Defaults to ./data/inbox-monitor in dev.
# INBOX_MONITOR_ATTACHMENTS_DIR=./data/inbox-monitor

# Software engineering briefs → routed to the scope intake pipeline.
SOFTWARE_EMAIL=software@example.com
SOFTWARE_EMAIL_PASS=replace-with-app-password
# SOFTWARE_EMAIL_IMAP_HOST=imap.gmail.com
# SOFTWARE_EMAIL_IMAP_PORT=993
# SOFTWARE_EMAIL_SMTP_HOST=smtp.gmail.com
# SOFTWARE_EMAIL_SMTP_PORT=587

# SEO / backlinks briefs → routed to the seo_backlinks skill.
# Body should include "Domain: <d>" and "Keywords: <csv>" lines.
SEO_EMAIL=seo@example.com
SEO_EMAIL_PASS=replace-with-app-password
# SEO_EMAIL_IMAP_HOST=imap.gmail.com
# SEO_EMAIL_IMAP_PORT=993
# SEO_EMAIL_SMTP_HOST=smtp.gmail.com
# SEO_EMAIL_SMTP_PORT=587

# Design briefs → queued as design tasks for the processor.
DESIGN_EMAIL=design@example.com
DESIGN_EMAIL_PASS=replace-with-app-password
# DESIGN_EMAIL_IMAP_HOST=imap.gmail.com
# DESIGN_EMAIL_IMAP_PORT=993
# DESIGN_EMAIL_SMTP_HOST=smtp.gmail.com
# DESIGN_EMAIL_SMTP_PORT=587

# Content writing briefs → queued as content tasks for the processor.
CONTENT_EMAIL=content@example.com
CONTENT_EMAIL_PASS=replace-with-app-password
# CONTENT_EMAIL_IMAP_HOST=imap.gmail.com
# CONTENT_EMAIL_IMAP_PORT=993
# CONTENT_EMAIL_SMTP_HOST=smtp.gmail.com
# CONTENT_EMAIL_SMTP_PORT=587

# Internal ops requests → queued as ops tasks for the processor.
OPS_EMAIL=ops@example.com
OPS_EMAIL_PASS=replace-with-app-password
# OPS_EMAIL_IMAP_HOST=imap.gmail.com
# OPS_EMAIL_IMAP_PORT=993
# OPS_EMAIL_SMTP_HOST=smtp.gmail.com
# OPS_EMAIL_SMTP_PORT=587
