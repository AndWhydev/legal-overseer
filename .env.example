# ─────────────────────────────────────────────────────────────────────
# Legal Overseer — environment variables
# Copy to .env and fill in. The defaults below are for local dev on a
# law firm server. Production deployments should harden every secret.
# ─────────────────────────────────────────────────────────────────────

# Operator notifications (email)
# Destination for daily briefings, system alerts, and matter intake
# fallback when INTAKE_LAWYER_EMAIL is not set.
ADMIN_EMAIL=managing.partner@firm.example

# Where new-matter intake notifications go (the responsible lawyer who
# triages every new enquiry). Falls back to ADMIN_EMAIL when unset.
INTAKE_LAWYER_EMAIL=intake@firm.example

# SMTP transport. Most firms use their existing on-prem Exchange / O365
# relay or a transactional sender (Postmark, SendGrid). Never reuse a
# client-facing mailbox credential here.
SMTP_HOST=smtp.firm.example
SMTP_PORT=587
SMTP_USER=overseer@firm.example
SMTP_PASS=replace-with-real-password

# Optional. Defaults: SMTP_FROM=SMTP_USER, SMTP_SECURE auto-detected
# (true only when SMTP_PORT=465). Override SMTP_SECURE=true to force TLS.
# SMTP_FROM="Legal Overseer <overseer@firm.example>"
# SMTP_SECURE=true

# Optional. Included as a link in alert emails so the partner can jump
# straight to the dashboard. No default.
# DASHBOARD_URL=http://127.0.0.1:3000

# ─────────────────────────────────────────────────────────────────────
# Anthropic
# Required when ENABLE_TASK_PROCESSOR=true. The platform calls Claude
# (Haiku / Sonnet / Opus) for classification + skill execution.
# Privilege-redaction runs locally BEFORE any text leaves the building.
# ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────
# SQLite path. Defaults to ./data/bitbit.db in dev, /data/bitbit.db
# in production. The on-prem deployment usually puts this on the firm's
# encrypted file share so backups are part of the normal IT rotation.
# DATABASE_PATH=./data/legal-overseer.db

# Where matter folders are created (one folder per matter_number).
# Use a path inside the firm's document management share.
# MATTER_FOLDERS_ROOT=/data/matters

# Default Australian jurisdiction for intake classification when the
# email doesn't make it explicit. NSW|VIC|QLD|WA|SA|TAS|ACT|NT|Cth.
DEFAULT_JURISDICTION=NSW

# ─────────────────────────────────────────────────────────────────────
# Task processor + overseer loop
# ─────────────────────────────────────────────────────────────────────
ENABLE_TASK_PROCESSOR=false
TASK_POLL_INTERVAL=5000
# Overseer tick interval (ms). Default 10 minutes.
OVERSEER_INTERVAL_MS=600000

# ─────────────────────────────────────────────────────────────────────
# Dashboard
# Local-only HTTP UI bound to 127.0.0.1. The firm's IT team typically
# fronts this with their existing internal reverse proxy if remote
# access is required.
# ─────────────────────────────────────────────────────────────────────
DASHBOARD_PORT=3000
# Set to "false" to skip starting the dashboard in the main process.
# ENABLE_DASHBOARD=false

# ─────────────────────────────────────────────────────────────────────
# Daily briefing
# Emails the managing partner a summary of matters, review queue,
# deadlines, billing, and system health at the configured cron time.
# ─────────────────────────────────────────────────────────────────────
BRIEFING_ENABLED=false
BRIEFING_CRON=0 8 * * *

# ─────────────────────────────────────────────────────────────────────
# Citation verifier
# Set to "true" to disable AustLII probes (offline mode / testing).
# When enabled, the verifier performs HEAD requests against AustLII
# and the Federal Register of Legislation with an 8-second timeout.
# ─────────────────────────────────────────────────────────────────────
# CITATION_VERIFIER_DISABLED=false

# ─────────────────────────────────────────────────────────────────────
# Inbox Monitor — four dedicated IMAP inboxes that drive the legal
# pipeline. Set ENABLE_INBOX_MONITOR=true and fill in *only* the slots
# you actually use; unconfigured slots are skipped silently.
#
# IMAP/SMTP host + port are auto-detected for Gmail, Office 365,
# iCloud, Fastmail, Yahoo, Zoho. For any other provider, set the
# *_IMAP_HOST and *_SMTP_HOST env vars explicitly.
# ─────────────────────────────────────────────────────────────────────
ENABLE_INBOX_MONITOR=false
# Override the 2-minute default poll. ≥30s recommended for IMAP politeness.
# INBOX_POLL_INTERVAL_MS=120000
# Where inbound attachments land before staging into matter folders.
# INBOX_MONITOR_ATTACHMENTS_DIR=./data/inbox-monitor

# --- LEGAL: new-matter intake -----------------------------------------
# Every email to this address creates a new matter (matter number,
# folder, audit entry, lawyer notification, auto-reply confirming
# receipt).
LEGAL_EMAIL=legal@firm.example
LEGAL_EMAIL_PASS=replace-with-app-password
# LEGAL_EMAIL_IMAP_HOST=outlook.office365.com
# LEGAL_EMAIL_IMAP_PORT=993
# LEGAL_EMAIL_SMTP_HOST=smtp.office365.com
# LEGAL_EMAIL_SMTP_PORT=587

# --- CLIENT: ongoing client correspondence ----------------------------
# Replies and follow-ups from existing clients. Pipeline tries to
# match the matter number from the subject and routes triage to the
# responsible lawyer.
CLIENT_EMAIL=client@firm.example
CLIENT_EMAIL_PASS=replace-with-app-password
# CLIENT_EMAIL_IMAP_HOST=outlook.office365.com
# CLIENT_EMAIL_IMAP_PORT=993
# CLIENT_EMAIL_SMTP_HOST=smtp.office365.com
# CLIENT_EMAIL_SMTP_PORT=587

# --- COURT: court / tribunal / regulator correspondence ---------------
# High-signal channel. Court correspondence is matter-matched by
# matter number in the subject and surfaced urgently to the
# responsible lawyer.
COURT_EMAIL=court@firm.example
COURT_EMAIL_PASS=replace-with-app-password
# COURT_EMAIL_IMAP_HOST=outlook.office365.com
# COURT_EMAIL_IMAP_PORT=993
# COURT_EMAIL_SMTP_HOST=smtp.office365.com
# COURT_EMAIL_SMTP_PORT=587

# --- INTERNAL: internal firm operations -------------------------------
# Admin, billing, IT. Triage only — never produces client-facing
# output.
INTERNAL_EMAIL=internal@firm.example
INTERNAL_EMAIL_PASS=replace-with-app-password
# INTERNAL_EMAIL_IMAP_HOST=outlook.office365.com
# INTERNAL_EMAIL_IMAP_PORT=993
# INTERNAL_EMAIL_SMTP_HOST=smtp.office365.com
# INTERNAL_EMAIL_SMTP_PORT=587

# ─────────────────────────────────────────────────────────────────────
# Firm-wide billing / costing (Section 1.5, 3.6, 6.1, 6.2, 6.3, 8.4)
# ─────────────────────────────────────────────────────────────────────
# Default lawyer charge-out rate in AUD per hour. Used by the cost
# estimator, profitability dashboard, and invoice generator when no
# matter-specific rate is set.
FIRM_LAWYER_RATE_AUD=450
# Conversion rate used when displaying USD AI cost as AUD billable.
USD_TO_AUD=1.5
# Used as the key into invoice_sequence so each firm has a separate
# invoice numbering sequence.
FIRM_ID=default
# GST rate applied by invoice-generator. AU default is 10 %.
GST_RATE=0.10

# ─────────────────────────────────────────────────────────────────────
# Dictation / transcription (5.4, 8.3)
# ─────────────────────────────────────────────────────────────────────
# Set to enable Whisper transcription. Audio is sent to OpenAI for
# transcription and never to Anthropic. The dictation route stores the
# upload as a recorded external action in the audit log.
# WHISPER_API_KEY=
# WHISPER_MODEL=whisper-1

# ─────────────────────────────────────────────────────────────────────
# SMS via Twilio (5.5)
# ─────────────────────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=+61...

# ─────────────────────────────────────────────────────────────────────
# AML lookup (4.1)
# ─────────────────────────────────────────────────────────────────────
# Optional external screening endpoint. The built-in screener uses a
# seed list of public watchlist names; for stricter coverage point this
# at an upstream provider. The endpoint should accept GET ?name=
# and return { "matches": [{ list, matched_name, reason, score }] }.
# AML_LOOKUP_URL=

# ─────────────────────────────────────────────────────────────────────
# Backups (7.6)
# ─────────────────────────────────────────────────────────────────────
# Set BACKUP_ENABLED=true to start the daily backup scheduler.
# BACKUP_ENABLED=false
# Passphrase used to derive the AES-256-GCM key. ALSO used to encrypt
# stored lawyer SMTP passwords (8.1). Rotate carefully.
# BACKUP_ENCRYPTION_PASSPHRASE=change-me-with-a-long-random-string
# Destination: local:/path | sftp:user@host:/path | s3:presigned-url
# BACKUP_DESTINATION=local:./data/backups
# BACKUP_LOCAL_DIR=./data/backups
# DATA_ROOT=./data

# ─────────────────────────────────────────────────────────────────────
# Monitoring (9.8)
# ─────────────────────────────────────────────────────────────────────
# Set to "false" to disable the monitoring scheduler. Default: enabled.
# MONITORING_ENABLED=true

# ─────────────────────────────────────────────────────────────────────
# Integrations (7.x) — each integration's full config is stored
# encrypted in the integration_configs SQLite table once the operator
# completes the OAuth flow in the dashboard. The environment vars
# below are only used by the install scripts.
# ─────────────────────────────────────────────────────────────────────
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=
# DOCUSIGN_ACCOUNT_ID=
# TEAMS_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────────────
# Custom branding / document roots (Section 9.5 + 2)
# ─────────────────────────────────────────────────────────────────────
# BRANDING_ROOT=./data/branding
# DOCUMENTS_ROOT=./data/documents
# PRECEDENTS_ROOT=./data/precedents
# REDLINE_ROOT=./data/redlines
# EXTERNAL_UPLOADS_ROOT=./data/external-counsel
# MATTER_FOLDERS_ROOT=./data/matters
