+function resolveTavilyApiKey(): string | null {
+  const envKey = process.env.TAVILY_API_KEY?.trim()
+  if (envKey) return envKey
+
+  try {
+    const configPath = join(homedir(), '.tavily', 'config.json')
+    if (!existsSync(configPath)) return null
+
+    const config = JSON.parse(readFileSync(configPath, 'utf-8')) as { api_key?: unknown }
+    const configKey = typeof config.api_key === 'string' ? config.api_key.trim() : ''
+    return configKey || null
+  } catch {
+    return null
+  }
+}
